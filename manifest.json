{
    "manifest_version": 3,
    "name": "YouTube to MP3 Converter Pro",
    "version": "2.0",
    "description": "유튜브 영상을 간편하게 MP3로 저장하세요.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_title": "MP3 저장 정보"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/watch?v=*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "host_permissions": [
        "http://127.0.0.1:8000/*"
    ]
}